<%- include("partials/header") %>

<main class="home-container">
  <!-- Banner Image -->
  <div class="banner-wrapper">
    <img src="<%= home.banner %>" alt="CSE Motors Banner" class="home-banner">
  </div>

  <!-- Welcome Message -->
  <section class="welcome-message">
    <h2><%= home.message %></h2>
    <p>Explore our wide range of vehicles, including Sedans, SUVs, Trucks, and Custom builds. Click a category above to get started!</p>
  </section>

  <!-- Quick Links / Categories -->
  <section class="home-categories">
    <h3>Browse By Classification</h3>
    <div class="categories-grid">
      <a href="/classification/Sedan" class="category-card">Sedan</a>
      <a href="/classification/SUV" class="category-card">SUV</a>
      <a href="/classification/Truck" class="category-card">Truck</a>
      <a href="/custom" class="category-card">Custom</a>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
