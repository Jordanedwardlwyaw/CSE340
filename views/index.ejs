<!DOCTYPE html>
<html lang="en">
  <%- include('partials/head') %>
  <body>
    <%- include('partials/header') %>
    <%- include('partials/nav') %>

    <main>
      <h1>Welcome to CSE Motors!</h1>

      <section class="hero">
        <div class="hero-text">
          <h2>DMC Delorean</h2>
          <ul>
            <li>3 Cup holders</li>
            <li>Superman doors</li>
            <li>Fuzzy dice!</li>
          </ul>
          <a href="#" class="btn">Own Today</a>
        </div>
        <img src="/images/delorean.webp" alt="DMC Delorean" class="car-image">
      </section>

      <section class="grid">
        <div>
          <h3>Delorean Upgrades</h3>
          <div class="upgrades">
            <img src="/images/flux-cap.jpg" alt="Flux Capacitor">
            <img src="/images/flame-decals.webp" alt="Flame Decals">
            <img src="/images/bumper-stickers.jpg" alt="Bumper Stickers">
            <img src="/images/Hub Caps.jpg" alt="Hub Caps">

          </div>
        </div>

        <div>
          <h3>DMC Delorean Reviews</h3>
          <ul class="reviews">
            <li>“So fast it’s almost like traveling in time.” (4/5)</li>
            <li>“Coolest ride on the road.” (4/5)</li>
            <li>“I’m feeling McFly!” (5/5)</li>
            <li>“The most futuristic ride of our day.” (4/5)</li>
            <li>“80’s livin’ and I love it!” (5/5)</li>
          </ul>
        </div>
      </section>
    </main>

    <%- include('partials/footer') %>
  </body>
</html>
