<%- include("partials/header") %>

<div class="container">
  <h2><%= type %> Vehicles</h2>

  <% vehicles.forEach(v => { %>
    <div class="vehicle-card">
      <img src="<%= v.image %>" alt="">
      <h3><%= v.make + " " + v.model %></h3>
      <p><%= v.description %></p>
      <a href="/vehicle/<%= v.id %>">View Details</a>
    </div>
  <% }) %>
</div>

<%- include("partials/footer") %>
