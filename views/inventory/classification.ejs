<%- include("partials/header") %>

<main class="container">
  <h2><%= type %> Vehicles</h2>

  <% vehicles.forEach(v => { %>
    <div class="vehicle-card">
      <img src="<%= v.image %>" alt="<%= v.make %> <%= v.model %>">
      <h3><%= v.make %> <%= v.model %></h3>
      <p><%= v.description %></p>
      <a href="/vehicle/<%= v.id %>">View Details</a>
    </div>
  <% }) %>
</main>

<%- include("partials/footer") %>
