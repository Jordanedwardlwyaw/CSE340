<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Custom Upgrades - CSE Motors</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header>
    <nav>
      <a href="/">Home</a>
      <a href="/inventory/custom">Custom</a>
      <a href="/inventory/sedan">Sedan</a>
      <a href="/inventory/suv">SUV</a>
      <a href="/inventory/truck">Truck</a>
    </nav>
  </header>

  <main>
    <h1>Custom Vehicle Upgrades</h1>
    <p>Select from the coolest car upgrades:</p>

    <section class="custom-grid">

      <div class="upgrade-card">
        <img src="/images/flux.jpg" alt="Flux Capacitor">
        <h3>Flux Capacitor</h3>
        <p>Time travel capabilities (not guaranteed).</p>
      </div>

      <div class="upgrade-card">
        <img src="/images/flames.jpg" alt="Flame Decals">
        <h3>Flame Decals</h3>
        <p>Add speed *visual* effect 😉.</p>
      </div>

      <div class="upgrade-card">
        <img src="/images/bumpers.jpg" alt="Bumper Stickers">
        <h3>Bumper Stickers</h3>
        <p>Choose from 100+ styles.</p>
      </div>

      <div class="upgrade-card">
        <img src="/images/hubcaps.jpg" alt="Hub Caps">
        <h3>Hub Caps</h3>
        <p>Premium metal or carbon fiber.</p>
      </div>

    </section>
  </main>

  <footer>
    <p>&copy; 2025 CSE Motors</p>
  </footer>
</body>
</html>
